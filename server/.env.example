# Server Environment Variables
# Copy this file to .env and fill in the values

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://designflow:designflow123@localhost:5432/designflow"

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# ─── Server ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# ─── Storage ────────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=50

# ─── Email ──────────────────────────────────────────────────
# Options: mailhog | gmail
EMAIL_MODE=mailhog

# MailHog (lokal testing)
MAILHOG_HOST=localhost
MAILHOG_PORT=1025

# Gmail SMTP (untuk kirim email sungguhan ke percetakan)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=emailkamu@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx   <- Google App Password

EMAIL_FROM_NAME="DesignFlow"
# EMAIL_FROM_ADDRESS=emailkamu@gmail.com
